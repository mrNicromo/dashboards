# В репозитории есть шаблон .env (без секретов). Реальные ключи — в .env.local
# (в .gitignore; читает dashboard/bootstrap.php после .env) или в переменных окружения сервера.

# =============================================================================
# Дашборды (dashboard/) — приоритет над dashboard/config.php
# =============================================================================

# Airtable
AIRTABLE_PAT=
AIRTABLE_BASE_ID=

AIRTABLE_DZ_TABLE_ID=
AIRTABLE_DZ_VIEW_ID=
AIRTABLE_PAID_VIEW_ID=
AIRTABLE_CS_TABLE_ID=
AIRTABLE_CS_VIEW_ID=
AIRTABLE_CHURN_TABLE_ID=
AIRTABLE_CHURN_VIEW_ID=
AIRTABLE_EXTRA_SOURCE_TABLE_IDS=

# Веб-авторизация (опционально)
# DASHBOARD_AUTH_ENABLED=1
# DASHBOARD_AUTH_USERNAME=
# DASHBOARD_AUTH_PASSWORD_HASH=
# DASHBOARD_AUTH_PASSWORD=

DASHBOARD_API_SECRET=

# DASHBOARD_DISABLE_DEBUG=1

# AI (ai_insights.php): нужен хотя бы один из двух ключей
DASHBOARD_GEMINI_API_KEY=
DASHBOARD_GROQ_API_KEY=

# Лимиты запросов AI (в час на сессию+IP): синхронизация с Airtable и вызовы LLM
# DASHBOARD_AI_RL_REFRESH=48
# DASHBOARD_AI_RL_LLM=15

# В JSON-ответ ai_insights_api добавить поле debug (размер контекста и т.д.)
# DASHBOARD_DEBUG_AI=1

# Опционально: URL для cron-скриптов (dashboard/scripts/)
# DASHBOARD_URL=http://127.0.0.1:8080

# =============================================================================
# Merchrules / импорт roadmap (dashboard/tools/)
# =============================================================================

MERCHRULES_API_TOKEN=
MERCHRULES_COOKIE=
MERCHRULES_BASE_URL=https://merchrules.any-platform.ru
