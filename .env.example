# Скопируйте в корень проекта:  cp .env.example .env
# Файл .env в git не попадает (см. .gitignore).

# =============================================================================
# Дашборды (dashboard/) — приоритет над dashboard/config.php при наличии в окружении
# =============================================================================

# Обязательно для работы с Airtable:
# AIRTABLE_PAT=pat_xxxxxxxxxxxxxxxx
# AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Веб-авторизация (опционально):
# DASHBOARD_AUTH_ENABLED=1
# DASHBOARD_AUTH_USERNAME=admin
# DASHBOARD_AUTH_PASSWORD_HASH=  # из php -r "echo password_hash('пароль', PASSWORD_DEFAULT);"
# DASHBOARD_AUTH_PASSWORD=       # только если без хэша (нежелательно в проде)

# Общий секрет для JSON API (api.php, *_api.php) при включённом логине — без сессии браузера:
# DASHBOARD_API_SECRET=длинная-случайная-строка

# Отключить отладочную страницу churn_fact_debug.php (ответ 404):
# DASHBOARD_DISABLE_DEBUG=1

# =============================================================================
# Merchrules / импорт roadmap (опционально, см. dashboard/tools/)
# =============================================================================
#
# Стабильная автоматизация: долгоживущий API token, если команда его выдаёт.
MERCHRULES_API_TOKEN=

# Временный обход: cookie сессии из браузера (протухает).
MERCHRULES_COOKIE=

# Нужен ровно один способ: MERCHRULES_API_TOKEN или MERCHRULES_COOKIE.
MERCHRULES_BASE_URL=https://merchrules.any-platform.ru
# MERCHRULES_BASE_URL=https://merchrules-qa.any-platform.ru
